# =========================================================================
# NutriFlow Monorepo Environment Variables Example
# =========================================================================

# 1. Apps/Web (Next.js 14) -> Da rinominare in apps/web/.env.local
NEXT_PUBLIC_SUPABASE_URL=https://<il-tuo-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<la-tua-chiave-anon-public>

# 2. Apps/Mobile (Expo) -> Da rinominare in apps/mobile/.env
EXPO_PUBLIC_SUPABASE_URL=https://<il-tuo-project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<la-tua-chiave-anon-public>